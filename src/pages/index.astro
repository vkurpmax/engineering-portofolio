---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { profile } from '@/data/portfolio';
const profilePhoto = '/assets/putu-herdy-profile.jpg';
const domains = ['Process Engineering', 'HVAC / AHU / VRF', 'Instrumentation', 'BMS / BAS', 'Pharmaceutical Engineering', 'Energy Efficiency'];
const focusAreas = [
  {
    title: 'Process & thermal systems',
    description: 'Engineering documentation, calculations, equipment coordination, and standards-based project support.'
  },
  {
    title: 'Facility reliability',
    description: 'HVAC, AHU, VRF, BMS/BAS, utilities, and field follow-up for disciplined facility operation.'
  },
  {
    title: 'Field instrumentation',
    description: 'Calibration, loop checking, troubleshooting, control valves, transmitters, and practical plant maintenance.'
  }
];
---
<BaseLayout title="Ir. Putu Herdy Kurniawan, S.Tr.T. - Engineering Portfolio" description="Professional engineering portfolio of Ir. Putu Herdy Kurniawan, S.Tr.T. covering pharmaceutical engineering, HVAC/BMS, process engineering, instrumentation, utility systems, and energy improvement.">
  <section class="relative overflow-hidden bg-white py-14 sm:py-20 lg:py-24">
    <div class="absolute inset-0 grid-paper opacity-35"></div>
    <div class="container-page relative grid min-w-0 gap-12 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
      <div class="min-w-0">
        <h1 class="text-balance text-4xl font-semibold leading-[1.04] text-slate-950 sm:text-5xl lg:text-6xl">
          {profile.name}
        </h1>
        <p class="mt-6 max-w-3xl text-2xl font-semibold leading-8 text-slate-900 sm:text-3xl sm:leading-10">
          Practical engineering for reliable process, facility, and control systems.
        </p>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-600">
          I connect process engineering, HVAC, instrumentation, BMS, pharmaceutical engineering, and energy efficiency into clear technical work: troubleshooting, documentation, coordination, and improvement follow-up.
        </p>

        <div class="mt-8 rounded-lg border border-slate-200 bg-slate-50 p-4 sm:p-5">
          <p class="eyebrow text-slate-500">Start here</p>
          <div class="mt-4 grid gap-3 sm:grid-cols-3">
            <a href="/portfolio" class="btn-primary w-full">View Portfolio</a>
            <a href="/resume" class="btn-secondary w-full">View Resume</a>
            <a href="/contact" class="btn-secondary w-full">Contact</a>
          </div>
        </div>

        <div class="mt-10 flex flex-wrap gap-2.5">
          {domains.map((domain) => (
            <span class="chip">{domain}</span>
          ))}
        </div>
      </div>
      <div class="min-w-0 lg:pl-4">
        <div class="engineering-card mx-auto max-w-[300px] overflow-hidden rounded-lg lg:ml-auto">
          <div class="p-3 sm:p-4">
            <img
              src={profilePhoto}
              alt="Putu Herdy Kurniawan in engineering workwear"
              class="aspect-square w-full rounded-md object-cover object-center"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-20">
    <div class="container-page">
      <SectionHeading eyebrow="Engineering focus" title="A portfolio built around practical technical execution." description="Concise case studies across facility engineering, process systems, controls, and energy-related improvement." />
      <div class="grid gap-4 md:grid-cols-3">
        {focusAreas.map((item, index) => (
          <article class="engineering-card rounded-lg p-6">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-lg bg-slate-950 text-sm font-semibold text-white">{String(index + 1).padStart(2, '0')}</div>
            <h3 class="text-xl font-semibold text-slate-950">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
