---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import EngineeringVisual from '@/components/EngineeringVisual.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { profile, expertise, projects } from '@/data/portfolio';
const featured = projects.slice(0, 2);
const domains = ['Pharmaceutical Engineering', 'HVAC / AHU / VRF', 'BMS / BAS', 'Instrumentation', 'Process Engineering', 'Energy Efficiency'];
---
<BaseLayout title="Ir. Putu Herdy Kurniawan, S.Tr.T. — Engineering Portfolio" description="Professional engineering portfolio of Ir. Putu Herdy Kurniawan, S.Tr.T. covering pharmaceutical engineering, HVAC/BMS, process engineering, instrumentation, utility systems, and energy improvement.">
  <section class="relative overflow-hidden bg-white py-16 sm:py-24 lg:py-28">
    <div class="absolute inset-0 grid-paper opacity-35"></div>
    <div class="absolute -left-24 top-10 h-80 w-80 rounded-full bg-blue-50 blur-3xl"></div>
    <div class="absolute right-0 top-0 h-px w-1/2 bg-gradient-to-r from-transparent via-blue-200 to-transparent"></div>
    <div class="container-page relative grid gap-12 lg:grid-cols-[1.04fr_0.96fr] lg:items-center">
      <div>
        <div class="mb-7 inline-flex items-center gap-3 rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-600">
          <span class="h-2 w-2 rounded-full bg-blueprint"></span>
          Engineering Portfolio
        </div>
        <h1 class="text-balance text-5xl font-semibold tracking-[-0.085em] text-slate-950 sm:text-6xl lg:text-7xl">
          {profile.name}
        </h1>
        <p class="mt-5 max-w-3xl text-xl font-medium leading-8 tracking-[-0.02em] text-slate-700">
          {profile.role}
        </p>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
          {profile.headline}
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a href="/portfolio" class="inline-flex items-center justify-center rounded-full bg-slate-950 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-slate-950/10 transition hover:-translate-y-0.5 hover:bg-blueprint">
            View portfolio
          </a>
          <a href="/resume" class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:border-slate-950">
            View resume
          </a>
        </div>
        <div class="mt-10 flex flex-wrap gap-2.5">
          {domains.map((domain) => (
            <span class="rounded-full border border-slate-200 bg-white px-3.5 py-2 text-sm font-medium text-slate-600 shadow-sm">{domain}</span>
          ))}
        </div>
      </div>
      <div class="lg:pl-6">
        <div class="relative rounded-[2rem] border border-slate-200 bg-slate-50/80 p-4 shadow-2xl shadow-slate-200/60">
          <div class="absolute -right-3 -top-3 h-20 w-20 rounded-full border border-blue-200"></div>
          <EngineeringVisual />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-24">
    <div class="container-page">
      <SectionHeading eyebrow="Selected expertise" title="Engineering capability built from field, process, and facility experience." description="A concise view of the technical areas behind the portfolio. Project pages provide the deeper case-study explanation." />
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {expertise.map((item, index) => (
          <article class="engineering-card group rounded-[1.5rem] p-6 transition hover:-translate-y-1 hover:border-blue-200">
            <div class="mb-5 flex h-10 w-10 items-center justify-center rounded-2xl bg-slate-950 text-sm font-semibold text-white">{String(index + 1).padStart(2, '0')}</div>
            <h3 class="text-xl font-semibold tracking-[-0.04em] text-slate-950">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-slate-600">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-white py-16 sm:py-24">
    <div class="container-page">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <SectionHeading eyebrow="Featured work" title="Selected project case studies." description="Each project page is written with context, challenge, role, approach, tools, and impact so the portfolio tells a complete engineering story." />
        <a href="/portfolio" class="mb-10 inline-flex w-fit rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:border-slate-950 hover:bg-slate-950 hover:text-white">All projects</a>
      </div>
      <div class="grid gap-6">
        {featured.map((project) => <ProjectCard project={project} featured />)}
      </div>
    </div>
  </section>
</BaseLayout>
