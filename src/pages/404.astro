---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found - Putu Herdy Portfolio">
  <section class="bg-white py-24">
    <div class="container-page text-center">
      <p class="eyebrow">404</p>
      <h1 class="mt-4 text-5xl font-semibold text-slate-950">Page not found</h1>
      <p class="mx-auto mt-4 max-w-xl text-slate-600">The page you are looking for does not exist or has been moved.</p>
      <a href="/" class="btn-primary mt-8">Back home</a>
    </div>
  </section>
</BaseLayout>
