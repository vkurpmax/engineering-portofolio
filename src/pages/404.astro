---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found — Putu Herdy Portfolio">
  <section class="bg-white py-24">
    <div class="container-page text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blueprint">404</p>
      <h1 class="mt-4 text-5xl font-semibold tracking-[-0.07em] text-slate-950">Page not found</h1>
      <p class="mx-auto mt-4 max-w-xl text-slate-600">The page you are looking for does not exist or has been moved.</p>
      <a href="/" class="mt-8 inline-flex rounded-full bg-slate-950 px-6 py-3 text-sm font-semibold text-white hover:bg-blueprint">Back home</a>
    </div>
  </section>
</BaseLayout>
