---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import ExperienceTimeline from '@/components/ExperienceTimeline.astro';
import { profile, tools, education, certifications } from '@/data/portfolio';
const toolGroups = [
  { title: 'Engineering Software', items: tools.engineering },
  { title: 'Automation / Control', items: tools.control },
  { title: 'Standards', items: tools.standards },
  { title: 'Field Knowledge', items: tools.field }
];
---
<BaseLayout title="Resume - Putu Herdy Kurniawan" description="Resume page for Putu Herdy Kurniawan: engineering experience, tools, standards, certifications, and education.">
  <section class="relative overflow-hidden border-b border-slate-200 bg-white py-16 sm:py-24">
    <div class="absolute inset-0 grid-paper opacity-30"></div>
    <div class="container-page relative grid gap-8 lg:grid-cols-[1fr_340px] lg:items-end">
      <SectionHeading
        eyebrow="Resume"
        title="Professional engineering resume."
        description="A clean overview of engineering roles, technical scope, tools, education, and supporting credentials. Each role links to a detailed experience page for deeper context."
      />
      <div class="rounded-lg border border-slate-200 bg-slate-950 p-6 text-white shadow-sm">
        <p class="eyebrow text-slate-300">Profile</p>
        <h2 class="mt-3 text-2xl font-semibold">Ir. {profile.name}, S.Tr.T.</h2>
        <p class="mt-3 text-sm leading-6 text-slate-300">{profile.role}</p>
        <p class="mt-4 text-sm font-semibold text-white">{profile.location}</p>
        <a href="/documents/cv-putu-herdy-kurniawan.pdf" class="mt-6 inline-flex rounded-lg bg-white px-5 py-3 text-sm font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-slate-100">
          Download CV
        </a>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 sm:py-20">
    <div class="container-page">
      <div class="mb-8">
        <SectionHeading
          eyebrow="Experience"
          title="Role history with detailed experience pages."
          description="Concise resume entries focused on responsibility, technical scope, and practical impact."
        />
      </div>
      <ExperienceTimeline />
    </div>
  </section>

  <section class="section-soft py-16 sm:py-20">
    <div class="container-page">
      <SectionHeading eyebrow="Capabilities" title="Tools and technical knowledge." />
      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {toolGroups.map((group) => (
          <div class="engineering-card rounded-lg p-6">
            <h3 class="text-lg font-semibold text-slate-950">{group.title}</h3>
            <div class="mt-5 flex flex-wrap gap-2">
              {group.items.map((item) => <span class="chip">{item}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 sm:py-20">
    <div class="container-page grid gap-8 lg:grid-cols-2">
      <div>
        <SectionHeading eyebrow="Education" title="Academic background." />
        <div class="space-y-4">
          {education.map((item) => (
            <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
              <p class="eyebrow text-slate-500">{item.period}</p>
              <h3 class="mt-2 text-xl font-semibold text-slate-950">{item.school}</h3>
              <p class="mt-2 text-base font-semibold text-slate-700">{item.credential}</p>
              <p class="mt-3 text-sm leading-6 text-slate-500">{item.note}</p>
            </article>
          ))}
        </div>
      </div>
      <div>
        <SectionHeading eyebrow="Certifications" title="Selected certifications and recognitions." />
        <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
          <ul class="space-y-3">
            {certifications.map((item) => (
              <li class="flex gap-3 rounded-lg bg-slate-50 p-4 text-sm font-medium text-slate-700">
                <span class="mt-1 h-2 w-2 rounded-sm bg-slate-950"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
