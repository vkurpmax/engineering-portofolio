---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { profile } from '@/data/portfolio';
const profilePhoto = '/assets/putu-herdy-profile.jpg';
---
<BaseLayout title="About - Putu Herdy Kurniawan" description="About Putu Herdy Kurniawan and his engineering portfolio focus.">
  <section class="relative overflow-hidden bg-white py-16 sm:py-20">
    <div class="absolute inset-0 grid-paper opacity-25"></div>
    <div class="container-page grid min-w-0 gap-12 lg:grid-cols-[1fr_0.9fr] lg:items-center">
      <div class="min-w-0">
        <SectionHeading eyebrow="About" title={profile.name} description={profile.headline} />
        <div class="space-y-5 text-lg leading-8 text-slate-600">
          <p>
            My background combines hands-on instrumentation work, process engineering delivery, and pharmaceutical facility engineering. This gives me a practical perspective: engineering is not only calculation or maintenance, but the ability to understand problems, coordinate stakeholders, and produce reliable outcomes.
          </p>
          <p>
            I am interested in roles and projects related to process engineering, pharmaceutical engineering, HVAC/BMS, instrumentation, utility systems, energy efficiency, and automation-enabled facility improvement.
          </p>
        </div>
      </div>
      <div class="engineering-card mx-auto max-w-[280px] overflow-hidden rounded-lg lg:ml-auto">
        <div class="p-3 sm:p-4">
          <img
            src={profilePhoto}
            alt="Putu Herdy Kurniawan in engineering workwear"
            class="aspect-square w-full rounded-md object-cover object-center"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
