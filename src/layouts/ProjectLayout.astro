---
import BaseLayout from './BaseLayout.astro';
import EngineeringVisual from '@/components/EngineeringVisual.astro';
import { projects } from '@/data/portfolio';
import type { Project } from '@/data/portfolio';

interface Props { project: Project; }
const { project } = Astro.props;
const related = projects.filter((item) => item.slug !== project.slug).slice(0, 3);
---
<BaseLayout title={`${project.title} — Putu Herdy Portfolio`} description={project.summary}>
  <section class="relative overflow-hidden border-b border-slate-200 bg-white py-16 sm:py-20">
    <div class="absolute inset-0 grid-paper opacity-50"></div>
    <div class="container-page relative grid gap-10 lg:grid-cols-[1fr_0.82fr] lg:items-center">
      <div>
        <a href="/portfolio" class="mb-7 inline-flex items-center rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-600 transition hover:border-slate-950 hover:text-slate-950">← Back to portfolio</a>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-blueprint">{project.eyebrow}</p>
        <h1 class="mt-4 text-balance text-4xl font-semibold tracking-[-0.075em] text-slate-950 sm:text-5xl lg:text-6xl">{project.title}</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">{project.summary}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <span class="rounded-full bg-slate-950 px-4 py-2 text-sm font-semibold text-white">{project.category}</span>
          <span class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-600">{project.year}</span>
          <span class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-600">{project.location}</span>
        </div>
      </div>
      <EngineeringVisual variant={project.coverStyle} />
    </div>
  </section>

  <section class="py-14 sm:py-20">
    <div class="container-page grid gap-10 lg:grid-cols-[260px_1fr]">
      <aside class="no-print lg:sticky lg:top-24 lg:h-fit">
        <div class="engineering-card rounded-[1.5rem] p-5">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Case study</p>
          <nav class="mt-4 space-y-2 text-sm font-medium text-slate-600">
            <a href="#overview" class="block rounded-xl px-3 py-2 hover:bg-slate-100 hover:text-slate-950">Overview</a>
            <a href="#challenge" class="block rounded-xl px-3 py-2 hover:bg-slate-100 hover:text-slate-950">Challenge</a>
            <a href="#role" class="block rounded-xl px-3 py-2 hover:bg-slate-100 hover:text-slate-950">Role</a>
            <a href="#impact" class="block rounded-xl px-3 py-2 hover:bg-slate-100 hover:text-slate-950">Impact</a>
            <a href="#details" class="block rounded-xl px-3 py-2 hover:bg-slate-100 hover:text-slate-950">Details</a>
          </nav>
        </div>
      </aside>

      <article class="project-prose">
        <div id="overview" class="grid gap-5 sm:grid-cols-3">
          {project.metrics.map((metric) => (
            <div class="engineering-card rounded-[1.5rem] p-6">
              <p class="text-3xl font-semibold tracking-[-0.06em] text-slate-950">{metric.value}</p>
              <p class="mt-2 text-sm leading-6 text-slate-500">{metric.label}</p>
            </div>
          ))}
        </div>

        <section id="challenge" class="mt-10 rounded-[2rem] border border-slate-200 bg-white p-6 sm:p-8">
          <h2>Problem / engineering challenge</h2>
          <p>{project.problem}</p>
        </section>

        <section id="role" class="mt-6 rounded-[2rem] border border-slate-200 bg-white p-6 sm:p-8">
          <h2>My role</h2>
          <p>{project.role}</p>
        </section>

        <section id="impact" class="mt-6 rounded-[2rem] border border-slate-200 bg-white p-6 sm:p-8">
          <h2>Outcome / impact</h2>
          <p>{project.outcome}</p>
        </section>

        <section class="mt-8 rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white sm:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-blue-200">Tools, systems, and references</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {project.tools.map((tool) => <span class="rounded-full border border-white/10 bg-white/10 px-3 py-1.5 text-sm text-slate-100">{tool}</span>)}
          </div>
        </section>

        <section id="details" class="mt-10">
          {project.sections.map((section) => (
            <div class="mb-8 rounded-[2rem] border border-slate-200 bg-white p-6 sm:p-8">
              <h2>{section.title}</h2>
              {section.body.map((paragraph) => <p>{paragraph}</p>)}
              {section.bullets && <ul>{section.bullets.map((bullet) => <li>{bullet}</li>)}</ul>}
            </div>
          ))}
        </section>

        <section class="mt-10 border-t border-slate-200 pt-10">
          <p class="mb-5 text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Explore more projects</p>
          <div class="grid gap-4 sm:grid-cols-3">
            {related.map((item) => (
              <a href={`/projects/${item.slug}`} class="rounded-3xl border border-slate-200 bg-white p-5 transition hover:-translate-y-1 hover:border-blue-200 hover:shadow-xl hover:shadow-slate-200/70">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-blueprint">{item.category}</p>
                <h3 class="mt-3 text-lg font-semibold tracking-[-0.04em] text-slate-950">{item.title}</h3>
              </a>
            ))}
          </div>
        </section>
      </article>
    </div>
  </section>
</BaseLayout>
