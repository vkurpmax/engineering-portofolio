---
import { experience } from '@/data/portfolio';
---
<div class="space-y-5">
  {experience.map((item, index) => (
    <article class="engineering-card rounded-[1.6rem] p-6 transition hover:-translate-y-1 hover:border-blue-200 hover:shadow-2xl hover:shadow-slate-200/70 sm:p-7">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
        <div class="flex gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-slate-950 text-sm font-semibold text-white">{String(index + 1).padStart(2, '0')}</div>
          <div>
            <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">{item.domain}</p>
            <h3 class="text-xl font-semibold tracking-[-0.04em] text-slate-950">{item.company}</h3>
            <p class="mt-1 text-sm font-semibold text-blueprint">{item.role}</p>
            <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">{item.summary}</p>
          </div>
        </div>
        <div class="shrink-0 rounded-2xl border border-slate-200 bg-white px-4 py-3 text-left sm:text-right">
          <p class="text-sm font-semibold text-slate-950">{item.period}</p>
          <p class="mt-1 text-xs text-slate-500">{item.location}</p>
        </div>
      </div>
      <ul class="mt-5 grid gap-3 border-t border-slate-200 pt-5 lg:grid-cols-3">
        {item.bullets.map((bullet) => (
          <li class="rounded-2xl bg-slate-50 p-4 text-sm leading-6 text-slate-600">{bullet}</li>
        ))}
      </ul>
      <div class="mt-5 flex justify-end">
        <a href={`/experience/${item.slug}`} class="inline-flex items-center rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-950 transition hover:border-slate-950 hover:bg-slate-950 hover:text-white">
          Read more about this role →
        </a>
      </div>
    </article>
  ))}
</div>
