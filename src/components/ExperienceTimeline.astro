---
import { experience } from '@/data/portfolio';
---
<div class="space-y-5">
  {experience.map((item, index) => (
    <article class="engineering-card rounded-lg p-6 transition hover:-translate-y-1 sm:p-8">
      <div class="grid gap-5 lg:grid-cols-[1fr_220px] lg:items-start">
        <div class="flex min-w-0 gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md bg-slate-950 text-sm font-semibold text-white">{String(index + 1).padStart(2, '0')}</div>
          <div class="min-w-0">
            <p class="eyebrow mb-2 text-slate-400">{item.domain}</p>
            <h3 class="text-2xl font-semibold leading-tight text-slate-950">{item.company}</h3>
            <p class="mt-2 text-base font-semibold text-slate-700">{item.role}</p>
          </div>
        </div>

        <dl class="grid gap-3 rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm">
          <div>
            <dt class="eyebrow text-slate-400">Period</dt>
            <dd class="mt-1 font-semibold text-slate-950">{item.period}</dd>
          </div>
          <div>
            <dt class="eyebrow text-slate-400">Location</dt>
            <dd class="mt-1 font-semibold text-slate-700">{item.location}</dd>
          </div>
        </dl>
      </div>

      <ul class="mt-6 space-y-3 border-t border-slate-200 pt-6">
        {item.bullets.map((bullet) => (
          <li class="flex gap-3 text-sm leading-6 text-slate-600">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-sm bg-slate-950"></span>
            <span>{bullet}</span>
          </li>
        ))}
      </ul>

      <div class="mt-6 flex flex-wrap items-center justify-between gap-3">
        <p class="text-sm leading-6 text-slate-500">{item.summary}</p>
        <a href={`/experience/${item.slug}`} class="btn-secondary px-4 py-2">
          Read more about this role
        </a>
      </div>
    </article>
  ))}
</div>
