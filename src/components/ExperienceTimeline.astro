---
import { experience } from '@/data/portfolio';
---
<div class="space-y-5">
  {experience.map((item, index) => (
    <article class="engineering-card rounded-lg p-6 transition hover:-translate-y-1 sm:p-7">
      <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:justify-between">
        <div class="flex gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-slate-950 text-sm font-semibold text-white">{String(index + 1).padStart(2, '0')}</div>
          <div>
            <p class="eyebrow mb-2 text-slate-400">{item.domain}</p>
            <h3 class="text-xl font-semibold text-slate-950">{item.company}</h3>
            <p class="mt-1 text-sm font-semibold text-blueprint">{item.role}</p>
            <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">{item.summary}</p>
          </div>
        </div>
        <div class="shrink-0 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-left sm:text-right">
          <p class="text-sm font-semibold text-slate-950">{item.period}</p>
          <p class="mt-1 text-xs text-slate-500">{item.location}</p>
        </div>
      </div>
      <ul class="mt-5 grid gap-3 border-t border-slate-200 pt-5 lg:grid-cols-3">
        {item.bullets.map((bullet) => (
          <li class="rounded-lg bg-slate-50 p-4 text-sm leading-6 text-slate-600">{bullet}</li>
        ))}
      </ul>
      <div class="mt-5 flex justify-end">
        <a href={`/experience/${item.slug}`} class="btn-secondary px-4 py-2">
          Read more about this role
        </a>
      </div>
    </article>
  ))}
</div>
