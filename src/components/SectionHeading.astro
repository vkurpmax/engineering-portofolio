---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, description, align = 'left' } = Astro.props;
---
<div class:list={['mb-10', align === 'center' ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl']}>
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class="text-balance text-3xl font-semibold text-slate-950 sm:text-4xl lg:text-5xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-7 text-slate-600 sm:text-lg">{description}</p>}
</div>
