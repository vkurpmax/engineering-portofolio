---
import { profile } from '@/data/portfolio';
const year = new Date().getFullYear();
---
<footer class="border-t border-slate-200 bg-white py-10">
  <div class="container-page flex flex-col justify-between gap-4 md:flex-row md:items-center">
    <div>
      <p class="text-sm font-semibold text-slate-950">{profile.name}</p>
      <p class="mt-1 max-w-xl text-sm text-slate-500">Engineering portfolio focused on practical engineering capability, project case studies, and measurable technical value.</p>
    </div>
    <p class="text-sm text-slate-400">Copyright {year}. Built with Astro, Tailwind CSS, and Cloudflare Workers Static Assets.</p>
  </div>
</footer>
