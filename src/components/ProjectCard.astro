---
import EngineeringVisual from './EngineeringVisual.astro';
import type { Project } from '@/data/portfolio';
interface Props { project: Project; featured?: boolean; }
const { project, featured = false } = Astro.props;
---
<article class:list={['group engineering-card overflow-hidden rounded-[1.8rem] transition duration-300 hover:-translate-y-1 hover:shadow-[0_28px_90px_rgba(15,23,42,0.10)]', featured ? 'grid gap-0 lg:grid-cols-[0.92fr_1.08fr]' : '']}>
  <a href={`/projects/${project.slug}`} class="block">
    <EngineeringVisual variant={project.coverStyle} compact />
  </a>
  <div class="p-6 sm:p-8">
    <div class="mb-4 flex flex-wrap items-center gap-2">
      <span class="rounded-full bg-blue-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-blueprint">{project.category}</span>
      <span class="text-xs text-slate-400">{project.year}</span>
    </div>
    <h3 class="text-balance text-2xl font-semibold tracking-[-0.05em] text-slate-950 sm:text-3xl">
      <a href={`/projects/${project.slug}`} class="hover:text-blueprint">{project.title}</a>
    </h3>
    <p class="mt-4 text-base leading-7 text-slate-600">{project.summary}</p>
    <div class="mt-6 grid gap-3 sm:grid-cols-3">
      {project.metrics.map((metric) => (
        <div class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4">
          <p class="text-lg font-semibold tracking-[-0.04em] text-slate-950">{metric.value}</p>
          <p class="mt-1 text-xs leading-5 text-slate-500">{metric.label}</p>
        </div>
      ))}
    </div>
    <div class="mt-7 flex items-center justify-between gap-4 border-t border-slate-200 pt-5">
      <span class="text-sm font-medium text-slate-500">{project.location}</span>
      <a href={`/projects/${project.slug}`} class="text-sm font-semibold text-blueprint hover:text-slate-950">Read case study →</a>
    </div>
  </div>
</article>
