---
import { navItems, profile } from '@/data/portfolio';
const current = Astro.url.pathname;
---
<header class="no-print sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur-xl">
  <div class="container-page flex h-[4.25rem] items-center justify-between gap-5">
    <a href="/" class="group flex items-center gap-3" aria-label="Go to home">
      <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-slate-200 bg-slate-950 text-xs font-semibold text-white shadow-sm transition group-hover:-translate-y-0.5 group-hover:bg-slate-800">
        PH
      </div>
      <div class="hidden leading-tight sm:block">
        <p class="text-sm font-semibold text-slate-950">{profile.shortName}</p>
        <p class="text-[11px] uppercase text-slate-500">Engineering Portfolio</p>
      </div>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
      {navItems.map((item) => {
        const active = item.href === '/' ? current === '/' : current.startsWith(item.href);
        return (
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-3.5 py-2 text-sm font-medium transition',
              active ? 'bg-slate-950 text-white' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-950'
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <a href="/contact" class="btn-primary px-4 py-2">
      Contact
    </a>
  </div>
</header>
